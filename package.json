{
  "name": "@matrix/core",
  "version": "2.0.0",
  "description": "Contratos canônicos da Matrix do Laboratório Sobral — schemas Zod compartilhados entre as entidades e apps.",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": ["dist", "src", "schema"],
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs && npm run build:jsonschema",
    "build:esm": "tsc -p tsconfig.json",
    "build:cjs": "tsc -p tsconfig.cjs.json && node scripts/fix-cjs.mjs",
    "build:jsonschema": "node scripts/gen-jsonschema.mjs",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build",
    "dev": "tsc --watch"
  },
  "keywords": ["matrix", "lab-sobral", "contracts", "zod"],
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "zod-to-json-schema": "^3.23.0"
  }
}
