{
  "$ref": "#/definitions/town-event",
  "definitions": {
    "town-event": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "ts": {
          "type": "integer"
        },
        "type": {
          "type": "string",
          "enum": [
            "file_saved",
            "git_branch_changed",
            "build_started",
            "build_finished",
            "test_run",
            "agent_action",
            "skill_used",
            "tick",
            "xp_earned",
            "level_up",
            "task_completed",
            "cycle_closed"
          ]
        },
        "workspace": {
          "type": "string"
        },
        "agent": {
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "builder",
                "reviewer",
                "architect",
                "scout",
                "fixer",
                "scribe"
              ]
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "district": {
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "town-square",
                "frontend",
                "backend",
                "build",
                "ops",
                "test"
              ]
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "skill_id": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "payload": {
          "type": "object",
          "additionalProperties": {},
          "default": {}
        }
      },
      "required": [
        "id",
        "ts",
        "type",
        "workspace"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
